{
  "id": "circuit_basic",
  "name": "Basic Circuit Lab",
  "description": "Explore series and parallel circuits, resistance, current, and bulb brightness.",
  "sceneType": "circuit",
  "subject": "physics",
  "concepts": ["series circuits", "parallel circuits", "resistance", "brightness"],
  "keywords": ["circuit", "electricity", "series", "parallel", "battery", "bulb", "resistance", "current", "physics"],
  "ageRange": [8, 12],
  "adjustableVariables": {
    "circuitType": {
      "type": "select",
      "label": "Circuit type",
      "options": ["series", "parallel"],
      "default": "series"
    },
    "numberOfBulbs": {
      "type": "range",
      "label": "Bulbs",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    "batteryVoltage": {
      "type": "range",
      "label": "Battery voltage",
      "min": 1.5,
      "max": 9,
      "step": 0.5,
      "unit": "V",
      "default": 6
    },
    "resistancePerBulb": {
      "type": "range",
      "label": "Resistance per bulb",
      "min": 1,
      "max": 10,
      "step": 0.5,
      "unit": "ohm",
      "default": 4
    }
  },
  "defaultHints": [
    "What happens to bulb brightness when you add another bulb in series?",
    "Compare total resistance between series and parallel setups."
  ],
  "safetyNotes": [
    "In a real circuit, short-circuiting a battery can cause overheating — this sim shows why safely."
  ]
}
